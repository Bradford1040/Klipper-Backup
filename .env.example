github_token=ghp_xxxxxxxxxxxxxxxx
github_username=USERNAME
github_repository=REPOSITORY
branch_name=main
commit_username=""
commit_email=""

# All information regarding .env can be found here:
# https://klipperbackup.xyz/configuration/

# Backup paths
# Note: script.sh starts its search in $HOME which is /home/{username}/
# The array accepts folders or files like the following example
# 
#  backupPaths=( \
#  "printer_data/config/*" \
#  "printer_data/config/printer.cfg" \
#  )
#
# Using the above example the script will search for `/home/{username}/printer_data/config/*` and `/home/{username}/printer_data/config/printer.cfg`
# When backing up a folder you should always have `/*` at the end of the path so that files inside the folder are properly searched 

backupPaths=( \
"printer_data/config/*" \
)

# Array of strings in .gitignore pattern git format https://git-scm.com/docs/gitignore#_pattern_format for files that should not be uploaded to the remote repo
# New additions must be enclosed in double quotes and should follow the pattern format as noted in the above link
exclude=( \
"*.swp" \
"*.tmp" \
"printer-[0-9]*_[0-9]*.cfg" \
"*.bak" \
"*.bkp" \
"*.csv" \
"*.zip" \
)

# String of additional filewatch excludes. names separated with a "|" reg-ex patterns can be used.
# Example extraFilewatchExclude="mmu_vars.cfg|macros.cfg"
extraFilewatchExclude=""

# Installer automation options (used by install.sh)
# install.sh is fully config-driven; installer_non_interactive is kept for backwards compatibility.
installer_non_interactive=true
installer_auto_update=true
installer_add_update_manager=false
installer_install_filewatch_service=false
installer_install_on_boot_service=false
installer_install_cron=false
installer_cron_schedule="0 */4 * * *"
# Optional runtime config path used by systemd + cron. Leave empty to reuse this file.
installer_runtime_config_path=""

# Restore automation options (used by utils/restore.sh)
# If empty, restore falls back to github_* and branch_name values above.
restore_github_token=""
restore_github_username=""
restore_github_repository=""
restore_branch_name=""
# Optional commit hash to restore from.
# If empty and running interactively, restore prompts you to choose a commit.
# If empty and non-interactive, restore uses the latest commit that contains restore data.
restore_commit_hash=""
